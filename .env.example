# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/paymesh?schema=public

# User Service gRPC
USER_GRPC_HOST=localhost
USER_GRPC_PORT=50051

# Wallet Service gRPC
WALLET_GRPC_PORT=50052

# Auth
# Shared API key required by both user-service and wallet-service.
# All inbound gRPC calls must include this value in the x-api-key metadata header.
# wallet-service also forwards this key automatically when calling user-service internally.
# Generate a strong random value for production: openssl rand -hex 32
GRPC_API_KEY=your-generated-key-here

# Application
NODE_ENV=development
LOG_LEVEL=info
