{
  "name": "paymesh",
  "private": true,
  "scripts": {
    "start": "bash pm2/start.sh",
    "build": "pnpm --filter @paymesh/user-service run build && pnpm --filter @paymesh/wallet-service run build",
    "lint": "eslint \"apps/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "pm2": "^6.0.14"
  }
}
